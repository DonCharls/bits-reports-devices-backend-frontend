generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Attendance {
  id                   Int                    @id @default(autoincrement())
  employeeId           Int
  date                 DateTime
  checkInTime          DateTime
  checkOutTime         DateTime?
  checkin_updated      DateTime?
  checkout_updated     DateTime?
  status               String                 @default("present")
  notes                String?
  checkInDeviceId      Int?
  checkOutDeviceId     Int?
  checkoutSource       String?
  createdAt            DateTime               @default(now())
  updatedAt            DateTime               @updatedAt
  employee             Employee               @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  AttendanceAdjustment AttendanceAdjustment[]
  checkInDevice        Device?                @relation("AttCheckIn", fields: [checkInDeviceId], references: [id])
  checkOutDevice       Device?                @relation("AttCheckOut", fields: [checkOutDeviceId], references: [id])

  @@unique([employeeId, date])
  @@index([date])
  @@index([employeeId])
  @@index([status])
}


model AttendanceAdjustment {
  id            Int @id @default(autoincrement())
  attendanceId  Int
  submittedById Int

  // Snapshot of original values at time of request
  originalCheckIn  DateTime?
  originalCheckOut DateTime?

  // Requested new values
  requestedCheckIn  DateTime?
  requestedCheckOut DateTime?

  reason String // Required — why the adjustment is needed

  // Approval workflow
  status          String  @default("pending") // pending, approved, rejected
  reviewedById    Int?
  rejectionReason String?

  submittedAt DateTime  @default(now())
  reviewedAt  DateTime?

  // Relations
  attendance  Attendance @relation(fields: [attendanceId], references: [id], onDelete: Cascade)
  submittedBy Employee   @relation("AdjustmentSubmittedBy", fields: [submittedById], references: [id])
  reviewedBy  Employee?  @relation("AdjustmentReviewedBy", fields: [reviewedById], references: [id])

  @@index([attendanceId])
  @@index([submittedById])
  @@index([status])
  @@index([submittedAt])
}

model AttendanceLog {
  id          Int       @id @default(autoincrement())
  timestamp   DateTime
  status      Int
  employeeId  Int
  deviceId    Int?
  createdAt   DateTime  @default(now())
  processedAt DateTime? // Stamped when this log is converted into an Attendance record; NULL = pending
  Device      Device?   @relation(fields: [deviceId], references: [id])
  employee    Employee  @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@unique([timestamp, employeeId])
  @@index([deviceId])
  @@index([employeeId])
  @@index([timestamp])
  @@index([processedAt]) // Enables fast filtering of unprocessed logs (WHERE processedAt IS NULL)
}

model Department {
  id        Int        @id @default(autoincrement())
  name      String     @unique
  createdAt DateTime   @default(now())
  updatedAt DateTime
  Employee  Employee[]
}

model Branch {
  id        Int        @id @default(autoincrement())
  name      String     @unique
  createdAt DateTime   @default(now())
  updatedAt DateTime
  Employee  Employee[]
}

model Device {
  id                            Int                             @id @default(autoincrement())
  name                          String
  ip                            String                          @unique
  port                          Int                             @default(4370)
  location                      String?
  isActive                      Boolean                         @default(true)
  syncEnabled                   Boolean                         @default(true)
  lastSyncedAt                  DateTime? // UTC timestamp of last processed log; null = never synced
  lastSyncStatus                String? // "SUCCESS", "FAILED"
  lastSyncError                 String? // Error message if FAILED
  lastPolledAt                  DateTime? // UTC timestamp of last successful heartbeat/check
  lastReconciledAt              DateTime? // UTC timestamp of last auto-reconcile; null = never reconciled
  createdAt                     DateTime                        @default(now())
  updatedAt                     DateTime
  AttendanceLog                 AttendanceLog[]
  EmployeeDeviceEnrollment      EmployeeDeviceEnrollment[]
  EmployeeFingerprintEnrollment EmployeeFingerprintEnrollment[]
  EmployeeCardEnrollment        EmployeeCardEnrollment[]
  AttendanceCheckIns            Attendance[]                    @relation("AttCheckIn")
  AttendanceCheckOuts           Attendance[]                    @relation("AttCheckOut")
  DeviceSyncTasks               DeviceSyncTask[]

  @@index([isActive])
  @@index([syncEnabled])
}

model Employee {
  id                  Int              @id @default(autoincrement())
  zkId                Int?             @unique
  cardNumber          Int?             @unique // RFID badge card number (uint32 from device offset 35)
  firstName           String
  lastName            String
  middleName          String?
  suffix              String?
  gender              String?
  dateOfBirth         DateTime?
  role                Role             @default(USER)
  email               String?          @unique
  password            String?
  needsPasswordChange Boolean          @default(false)
  employmentStatus    EmploymentStatus @default(ACTIVE)

  // Secondary Info
  position       String?
  contactNumber  String?          @unique
  employeeNumber String?   @unique
  hireDate       DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime

  // Relations
  departmentId                  Int?
  branchId                      Int?
  shiftId                       Int?
  Attendance                    Attendance[]
  AttendanceLog                 AttendanceLog[]
  RefreshToken                  RefreshToken[]
  EmployeeDeviceEnrollment      EmployeeDeviceEnrollment[]
  EmployeeFingerprintEnrollment EmployeeFingerprintEnrollment[]
  EmployeeCardEnrollment        EmployeeCardEnrollment[]
  Department                    Department?                     @relation(fields: [departmentId], references: [id])
  Branch                        Branch?                         @relation(fields: [branchId], references: [id])
  Shift                         Shift?                          @relation(fields: [shiftId], references: [id])
  AuditLogs                     AuditLog[]
  AdjustmentsSubmitted          AttendanceAdjustment[]          @relation("AdjustmentSubmittedBy")
  AdjustmentsReviewed           AttendanceAdjustment[]          @relation("AdjustmentReviewedBy")

  @@index([departmentId])
  @@index([branchId])
  @@index([shiftId])
  @@index([email])
  @@index([employeeNumber])
  @@index([employmentStatus])
  @@index([role])
}

model Shift {
  id           Int        @id @default(autoincrement())
  shiftCode    String     @unique
  name         String     @unique
  startTime    String
  endTime      String
  graceMinutes Int        @default(0)
  breakMinutes Int        @default(60)
  isNightShift Boolean    @default(false)
  isActive     Boolean    @default(true)
  description  String?
  workDays     String     @default("[\"Mon\",\"Tue\",\"Wed\",\"Thu\",\"Fri\"]")
  halfDays     String     @default("[]")
  halfDayHours Float?     // When set, half-day expected hours = this value; when null, midpoint is used
  breaks       String     @default("[]")
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  Employee     Employee[]

  @@index([isActive])
}

model RefreshToken {
  id         Int      @id @default(autoincrement())
  token      String   @unique
  employeeId Int
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  employee   Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@index([employeeId])
  @@index([token])
  @@index([expiresAt])
}

model EmployeeDeviceEnrollment {
  id         Int      @id @default(autoincrement())
  employeeId Int
  deviceId   Int
  enrolledAt DateTime @default(now())

  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  device   Device   @relation(fields: [deviceId], references: [id], onDelete: Cascade)

  @@unique([employeeId, deviceId])
  @@index([employeeId])
  @@index([deviceId])
}

model EmployeeFingerprintEnrollment {
  id          Int      @id @default(autoincrement())
  employeeId  Int
  deviceId    Int
  fingerIndex Int // 0-9 (ZKTeco standard)
  fingerLabel String // "Right Thumb", "Left Index Finger", etc.
  enrolledAt  DateTime @default(now())

  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  device   Device   @relation(fields: [deviceId], references: [id], onDelete: Cascade)

  @@unique([employeeId, deviceId, fingerIndex])
  @@index([employeeId])
  @@index([deviceId])
}

model EmployeeCardEnrollment {
  id         Int      @id @default(autoincrement())
  employeeId Int
  deviceId   Int
  enrolledAt DateTime @default(now())

  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  device   Device   @relation(fields: [deviceId], references: [id], onDelete: Cascade)

  @@unique([employeeId, deviceId])
  @@index([employeeId])
  @@index([deviceId])
}

model AuditLog {
  id          Int      @id @default(autoincrement())
  timestamp   DateTime @default(now())
  level       String   @default("INFO") // INFO, WARN, ERROR
  action      String // CREATE, UPDATE, DELETE, LOGIN, LOGOUT, SYNC, CHECK_IN, CHECK_OUT, etc.
  entityType  String // Employee, Device, Attendance, Shift, Department, Branch, Account, System
  entityId    Int? // ID of the affected entity (nullable for system-wide events)
  performedBy Int? // Employee ID of the actor (nullable for system/cron actions)
  source      String   @default("system") // "admin-panel", "api", "cron", "device-sync", etc.
  details     String? // Human-readable summary
  metadata    Json? // Optional JSON: old/new values, IP, device info, etc.
  category    String   @default("system") // "auth", "attendance", "device", "employee", "config", "system"
  correlationId String? // UUID for request tracing

  performer Employee? @relation(fields: [performedBy], references: [id], onDelete: SetNull)

  @@index([timestamp])
  @@index([action])
  @@index([entityType])
  @@index([performedBy])
  @@index([level])
  @@index([category])
  @@index([correlationId])
}

enum EmploymentStatus {
  ACTIVE
  INACTIVE
  TERMINATED
}

enum Role {
  USER
  ADMIN
  HR
}

model SyncConfig {
  id                           Int      @id @default(1) // Singleton — always row id=1
  globalSyncEnabled            Boolean  @default(true)
  defaultIntervalSec           Int      @default(30) // Default sync interval in seconds
  highFreqIntervalSec          Int      @default(30) // Near-shift interval
  lowFreqIntervalSec           Int      @default(600) // Off-peak interval (10 min)
  shiftAwareSyncEnabled        Boolean  @default(false) // Feature 5 toggle
  shiftBufferMinutes           Int      @default(120) // ±2 hour window around shift start/end
  autoTimeSyncEnabled          Boolean  @default(true) // Enable background clock sync
  timeSyncIntervalSec          Int      @default(3600) // How often to sync device clocks (1 hour)
  globalMinCheckoutMinutes     Int      @default(120) // Ensure checkout is valid only if diff >= minimum 
  healthCheckEnabled           Boolean  @default(true) // Independent device health monitoring (TCP ping)
  healthCheckIntervalSec       Int      @default(60) // How frequency to ping devices for connectivity (seconds)
  logBufferMaintenanceEnabled  Boolean  @default(true) // Scheduled device log buffer clearing
  logBufferMaintenanceSchedule String   @default("weekly") // "daily" | "weekly" | "monthly"
  logBufferMaintenanceHour     Int      @default(3) // PHT hour to run the job (0-23)
  updatedAt                    DateTime @updatedAt
}

model DeviceSyncTask {
  id         Int      @id @default(autoincrement())
  deviceId   Int
  actionType String // e.g. 'UPSERT_USER', 'DELETE_USER', 'DELETE_FINGER'
  entityId   String // e.g. 'USER_5', 'FINGER_5_1'
  payload    Json // Raw data to send
  status     String   @default("PENDING") // 'PENDING', 'SUCCESS', 'DEAD_LETTER'
  retryCount Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  device Device @relation(fields: [deviceId], references: [id], onDelete: Cascade)

  @@unique([deviceId, actionType, entityId])
  @@index([deviceId, status])
  @@index([createdAt])
}
